/* pages/chat/chat.wxss */

/* ── Layout ── */
.page {
  height: 100vh;
  display: flex;
  position: relative;
  overflow: hidden;
}

/* ============================================
   SIDEBAR
   ============================================ */
.sidebar-mask {
  position: fixed;
  left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 100;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s ease;
}
.sidebar-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.sidebar {
  position: fixed;
  left: 0; top: 0; bottom: 0;
  width: 560rpx;
  z-index: 200;
  background: #FFF;
  display: flex;
  flex-direction: column;
  transform: translateX(-100%);
  transition: transform 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.sidebar.open {
  transform: translateX(0);
}

.sidebar-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 28rpx 20rpx;
}
.sidebar-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1D1D1F;
}
.sidebar-close {
  width: 48rpx; height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  font-size: 28rpx;
  color: #8E8E93;
  background: #F2F3F7;
  border-radius: 50%;
}

/* 账号行 */
.account-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 28rpx;
  margin: 0 20rpx;
  background: #F7F8FA;
  border-radius: 20rpx;
}
.account-avatar {
  width: 64rpx; height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  background: var(--primary-gradient);
  color: #FFF;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 50%;
  flex-shrink: 0;
}
.account-meta {
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.account-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1D1D1F;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.account-hint {
  font-size: 22rpx;
  color: var(--primary);
  margin-top: 2rpx;
}

/* 新建对话 */
.new-chat-cell {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx 28rpx;
  margin: 16rpx 20rpx;
  background: var(--primary-light);
  border-radius: 20rpx;
}
.new-chat-cell:active { opacity: 0.7; }
.new-chat-icon {
  width: 44rpx; height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  background: var(--primary);
  color: #FFF;
  font-size: 28rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.new-chat-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
}

/* 切换面板 */
.switch-panel {
  margin: 12rpx 20rpx;
  padding: 20rpx;
  background: #F7F8FA;
  border-radius: 20rpx;
}
.switch-input {
  height: 72rpx;
  font-size: 28rpx;
  color: #1D1D1F;
  background: #FFF;
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}
.switch-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 16rpx;
}
.switch-cancel {
  font-size: 26rpx;
  color: #8E8E93;
  padding: 10rpx 24rpx;
}
.switch-ok {
  font-size: 26rpx;
  color: #FFF;
  background: var(--primary);
  padding: 10rpx 32rpx;
  border-radius: 20rpx;
  font-weight: 600;
}
.switch-ok:active { opacity: 0.8; }

/* 对话列表 */
.conv-list {
  flex: 1;
  overflow-y: auto;
  padding: 8rpx 0 40rpx;
}
.conv-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 28rpx;
  margin: 2rpx 12rpx;
  border-radius: 20rpx;
  transition: background 0.15s;
}
.conv-item:active { background: #F2F3F7; }
.conv-item.active { background: var(--primary-light); }
.conv-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}
.conv-info {
  flex: 1;
  overflow: hidden;
}
.conv-title {
  font-size: 28rpx;
  color: #1D1D1F;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.conv-item.active .conv-title { color: var(--primary); font-weight: 600; }
.conv-time {
  font-size: 22rpx;
  color: #B0B0B8;
  display: block;
  margin-top: 4rpx;
}
.empty-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 80rpx 0;
  color: #B0B0B8;
  font-size: 26rpx;
}
.empty-icon { font-size: 48rpx; }

/* ============================================
   CHAT AREA
   ============================================ */
.chat-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F2F3F7;
}

/* ── Top bar ── */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  flex-shrink: 0;
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
  box-sizing: border-box;
}
.top-left, .top-right {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.hamburger {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 10rpx;
}
.hamburger-line {
  width: 36rpx;
  height: 4rpx;
  background: #1D1D1F;
  border-radius: 2rpx;
  transition: background 0.15s;
}
.hamburger:active .hamburger-line { background: var(--primary); }
.top-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1D1D1F;
  letter-spacing: 0.04em;
}

/* ── Messages ── */
.messages {
  flex: 1;
  overflow-y: scroll;
  padding: 16rpx 0 24rpx;
  -webkit-overflow-scrolling: touch;
}

/* ── Welcome ── */
.welcome {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx 60rpx;
}
.welcome-logo {
  width: 120rpx; height: 120rpx;
  border-radius: 32rpx;
  background: var(--primary-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(78, 110, 242, 0.25);
}
.welcome-char {
  font-size: 56rpx;
  color: #FFF;
  font-weight: 700;
}
.welcome-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #1D1D1F;
  margin-bottom: 12rpx;
}
.welcome-desc {
  font-size: 28rpx;
  color: #8E8E93;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 48rpx;
}

/* 推荐问题 */
.suggestions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}
.suggest-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 26rpx 28rpx;
  background: #FFF;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #1D1D1F;
  box-shadow: var(--shadow-sm);
  transition: all 0.15s;
}
.suggest-item:active {
  background: var(--primary-light);
  transform: scale(0.98);
}
.suggest-icon { font-size: 36rpx; }

/* ── Loading ── */
.loading-indicator {
  display: flex;
  padding: 16rpx 28rpx;
  animation: fadeUp 0.25s ease;
}
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(12rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
.loading-bubble {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background: #FFF;
  border-radius: 20rpx;
  border-bottom-left-radius: 8rpx;
  box-shadow: var(--shadow-sm);
}
.thinking-dots {
  display: flex;
  gap: 8rpx;
  align-items: center;
}
.t-dot {
  width: 10rpx; height: 10rpx;
  background: var(--primary);
  border-radius: 50%;
  opacity: 0.4;
  animation: dotBounce 1.2s ease-in-out infinite;
}
.t-dot:nth-child(2) { animation-delay: 0.2s; }
.t-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes dotBounce {
  0%, 80%, 100% { opacity: 0.2; transform: scale(0.8); }
  40% { opacity: 0.6; transform: scale(1.2); }
}

/* ── Input area ── */
.input-shell {
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: transparent;
}
.input-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 8rpx 8rpx 8rpx 28rpx;
  background: #FFF;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  border: 2rpx solid transparent;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.input-card:focus-within {
  border-color: var(--primary);
  box-shadow: 0 4rpx 20rpx rgba(78, 110, 242, 0.12);
}
.input-card.disabled {
  opacity: 0.6;
}
.input-field {
  flex: 1;
  height: 76rpx;
  font-size: 30rpx;
  color: #1D1D1F;
  background: transparent;
  border: none;
  outline: none;
}
.send-icon {
  width: 68rpx; height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #E8E8ED;
  border-radius: 50%;
  flex-shrink: 0;
  transition: all 0.2s;
}
.send-icon.active {
  background: var(--primary);
  box-shadow: 0 4rpx 12rpx rgba(78, 110, 242, 0.3);
}
.send-arrow {
  font-size: 32rpx;
  color: #FFF;
  font-weight: 700;
}
.send-icon:not(.active) .send-arrow {
  color: #B0B0B8;
}
.send-icon:active {
  transform: scale(0.92);
}
